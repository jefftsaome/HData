# Docker 构建上下文裁剪（上下文 = 仓库根）
# 目标：① 敏感信息绝不进镜像 ② 上下文尽量小

.git
.venv
__pycache__
*.pyc
*.egg-info
.pytest_cache
.cache
.vscode
node_modules

# 数据与日志（含采集数据库、归档）
data/
*.log
hsys/crawl-bot/data/
hsys/crawl-bot/logs/

# 敏感配置（运行时 -v 挂载）
hsys/crawl-bot/config.json
.auth_cache.json
.session_cache.json
.chrome_profile/

# 与镜像无关的大目录
docs/
viewer/
tests/
scripts/
dist/
build/
*.c
*.so
*.pyd
